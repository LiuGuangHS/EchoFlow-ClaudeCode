{
  "name": "codemobile",
  "private": true,
  "version": "0.4.2",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android",
    "android:build": "expo run:android --variant debug",
    "android:release": "cd android && ./gradlew assembleRelease --console=plain --no-daemon",
    "android:release:arm64": "cd android && ./gradlew assembleRelease --console=plain --no-daemon \"-Pandroid.enableSeparateBuildPerCPUArchitecture=true\" \"-PreactNativeArchitectures=arm64-v8a\"",
    "typecheck": "tsc --noEmit",
    "typecheck:tests": "tsc -p tsconfig.test.json",
    "test": "bun test",
    "check": "bun run typecheck && bun run typecheck:tests && bun run test",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^3.1.1",
    "expo": "^54.0.0",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-secure-store": "~15.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "bun-types": "^1.3.14",
    "typescript": "^5.9.3"
  }
}
